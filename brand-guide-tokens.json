{
  "$comment": "Sample client token set — Acme Co. Replace all values with the client's brand. Keys map 1:1 to theme.json token surface; omit any key to keep the theme default.",
  "client": "acme-co",
  "colors": {
    "primary":       "#E53E3E",
    "secondary":     "#DD6B20",
    "accent":        "#38A169",
    "neutral-light": "#F7FAFC",
    "neutral-dark":  "#2D3748",
    "background":    "#FFFFFF",
    "text":          "#1A202C"
  },
  "typography": {
    "body-font-family":    "Georgia, 'Times New Roman', Times, serif",
    "heading-font-family": "'Playfair Display', Georgia, serif",
    "line-height-body":    "1.7",
    "line-height-heading": "1.25"
  },
  "spacing": {
    "small":  "1rem",
    "medium": "2rem",
    "large":  "4rem",
    "xlarge": "7rem"
  },
  "radius": {
    "button": "0",
    "card":   "0.25rem",
